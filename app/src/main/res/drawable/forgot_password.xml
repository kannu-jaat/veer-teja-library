<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B1A"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingLeft="28dp"
    android:paddingRight="28dp"
    android:paddingTop="40dp"
    android:paddingBottom="20dp">

    <!-- Sleek Lock Icon -->
    <TextView
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/glass_card"
        android:gravity="center"
        android:text="🔒"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Forgot Password?"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="35dp"
        android:layout_marginTop="8dp"
        android:text="Enter your registered username. We will send a request to the Admin to reset your password. Contact Admin for Approval"
        android:textColor="#e31ee0"
        android:gravity="center"
        android:textSize="13sp" />

    <!-- USERNAME FIELD (Sleek & Neon) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="#3B82F6"
            android:textSize="11sp"
            android:layout_marginLeft="6dp"
            android:layout_marginBottom="4dp"/>
            
        <EditText
            android:id="@+id/etForgotUsername"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input_neon"
            android:drawableLeft="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="12dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textColorHint="#475569"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- Premium Sleek Button -->
    <Button
        android:id="@+id/btnResetRequest"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_btn_gradient"
        android:text="Send Request   →"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:textAllCaps="false"/>

    <!-- Back to Login Link -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="28dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remembered your password? "
            android:textColor="#64748B"
            android:textSize="13sp"/>
            
        <TextView
            android:id="@+id/tvBackToLoginForgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textColor="#3B82F6"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>