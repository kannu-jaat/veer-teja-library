<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavLayout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. DARK HEADER SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="#0F172A"> <!-- Temporary Dark Blue, jab image daloge yahan set hogi -->

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_library_banner"
                    android:alpha="0.6"/> <!-- Dark overlay effect -->

                <!-- Top Menu Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:tint="#FFFFFF"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvHeaderAvatar"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_alignParentRight="true"
                        app:cardCornerRadius="22.5dp">
                        <ImageView
                            android:id="@+id/ivHeaderAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_camera"/>
                    </androidx.cardview.widget.CardView>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_toLeftOf="@id/cvHeaderAvatar"
                        android:layout_marginRight="15dp"
                        android:layout_marginTop="8dp"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:tint="#FFFFFF"/>
                </RelativeLayout>

                <!-- Welcome Text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentBottom="true"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:paddingBottom="50dp">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back,"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvDashName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#FBBF24"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay focused, stay consistent."
                        android:textColor="#E2E8F0"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Active Member Pill -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#1E293B"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardMaxElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="#10B981" android:layout_marginRight="8dp"/>
                            <TextView android:id="@+id/tvMemberStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active Member" android:textColor="#F8FAFC" android:textSize="12sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </RelativeLayout>

            <!-- 2. PREMIUM MEMBERSHIP CARD (Overlapping) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginTop="-30dp"
                app:cardBackgroundColor="#1E1B4B"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="15dp"
                    android:baselineAligned="false">
                    
                    <!-- Crown & Membership -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@android:drawable/btn_star_big_on" android:tint="#FBBF24" android:layout_marginRight="10dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Membership" android:textColor="#CBD5E1" android:textSize="10sp"/>
                            <TextView android:id="@+id/tvMembershipType" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Premium" android:textColor="#FBBF24" android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:id="@+id/tvValidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Valid till --" android:textColor="#CBD5E1" android:textSize="9sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Days Present -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_today" android:tint="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Days Present" android:textColor="#CBD5E1" android:textSize="9sp"/>
                    </LinearLayout>

                    <!-- Seat No -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#FFFFFF"/>
                        <TextView android:id="@+id/tvSeatNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A12" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seat No." android:textColor="#CBD5E1" android:textSize="9sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. QUICK ACCESS GRID (4x2) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Access"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:paddingLeft="12dp"
                android:paddingRight="12dp">
                
                <!-- Mark Attendance (Green) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_badge_green">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_camera" android:tint="#10B981"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mark\nAttend" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- My Attendance (Blue) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#EFF6FF">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_today" android:tint="#3B82F6"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My\nAttend" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- My Seat (Purple) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#F3E8FF">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_view" android:tint="#A855F7"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Seat\n(A12)" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Fees & Payments (Orange) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#FFF7ED">
                    <TextView android:layout_width="28dp" android:layout_height="28dp" android:text="₹" android:textColor="#F97316" android:textSize="20sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fees &amp;\nPayment" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Notices (Red) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#FEF2F2">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_info_details" android:tint="#EF4444"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notices" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Library Rules (Teal) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#F0FDFA">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#14B8A6"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rules" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Profile (Indigo) -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_margin="8dp" android:padding="10dp" android:background="@drawable/bg_input_neon" android:backgroundTint="#EEF2FF">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_myplaces" android:tint="#6366F1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- SUPPORT BUTTON (Blue) -->
                <LinearLayout
                    android:id="@+id/btnSupport"
                    android:layout_width="0dp" 
                    android:layout_height="wrap_content" 
                    android:layout_columnWeight="1" 
                    android:orientation="vertical" 
                    android:gravity="center" 
                    android:layout_margin="8dp" 
                    android:padding="10dp" 
                    android:background="@drawable/bg_input_neon" 
                    android:backgroundTint="#F0F9FF">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_call" android:tint="#0EA5E9"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Support" android:textColor="#0F172A" android:textSize="10sp" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>

            </GridLayout>

            <!-- 4. TODAY'S ATTENDANCE STATUS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    
                    <TextView android:id="@+id/tvStatusTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today's Attendance" android:textColor="#0F172A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTodayStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvStatusTitle" android:text="Marked ✓" android:textColor="#10B981" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                    
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvTodayStatus" android:layout_marginTop="10dp" android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25 May 2026" android:textColor="#64748B" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  •  09:15 AM" android:textColor="#64748B" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Circular Photo in Status -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="30dp">
                        <ImageView
                            android:id="@+id/ivStatusAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_camera"/>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            
            <View android:layout_width="match_parent" android:layout_height="90dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- 5. DARK THEME BOTTOM NAV -->
    <RelativeLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_alignParentBottom="true"
            android:background="#1E1B4B"
            android:orientation="horizontal"
            android:paddingTop="8dp">
            
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_view" android:tint="#FBBF24"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dashboard" android:textColor="#FBBF24" android:textSize="10sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_today" android:tint="#94A3B8"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attend" android:textColor="#94A3B8" android:textSize="10sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Space for Floating Button -->
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_manage" android:tint="#94A3B8"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payments" android:textColor="#94A3B8" android:textSize="10sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_more" android:tint="#94A3B8"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="More" android:textColor="#94A3B8" android:textSize="10sp" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Floating Yellow Scan Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            app:cardBackgroundColor="#F59E0B"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#FFFFFF"/>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
</RelativeLayout>